# Arogga UI environment example
NEXT_PUBLIC_SITE_URL=https://www.arogga.com

# Repository/data mode
DATA_SOURCE=local
API_BASE_URL=

# Auth/session
AUTH_SESSION_SECRET=replace-with-32-byte-random-secret
OTP_PROVIDER=demo
OTP_DEMO_CODE=123456
OTP_EXPIRES_SECONDS=300
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MS=60000
OTP_RATE_LIMIT_MAX=5

# Search adapters prepared for future production catalog scale
SEARCH_PROVIDER=json
TYPESENSE_HOST=
TYPESENSE_API_KEY=
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_KEY=
OPENSEARCH_URL=

# Payments: never expose secret keys in NEXT_PUBLIC variables
BKASH_APP_KEY=
BKASH_APP_SECRET=
NAGAD_MERCHANT_ID=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_SECRET=

# Uploads and webhooks
MAX_PRESCRIPTION_UPLOAD_MB=5
WEBHOOK_SIGNING_SECRET=

# Observability
SENTRY_DSN=
POSTHOG_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
